<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LottoPro | Tu App de Sorteos</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="manifest" href="manifest.json">
    <style>
        .tab-content { display: none; }
        .tab-content.active { display: block; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">

    <div class="bg-slate-900 py-6 text-white text-center shadow-lg">
        <h1 class="text-3xl font-bold">Lotto<span class="text-amber-500">Pro</span></h1>
    </div>

    <nav class="bg-white p-4 shadow-sm flex justify-center gap-4 overflow-x-auto text-sm md:text-base">
        <button onclick="showTab('jugar')" class="font-bold text-blue-900">Jugar</button>
        <button onclick="showTab('estrategia')" class="font-bold text-blue-900">Estrategias</button>
        <button onclick="showTab('calendario')" class="font-bold text-blue-900">Calendario</button>
        <button onclick="showTab('historial')" class="font-bold text-blue-900">Historial</button>
        <button onclick="showTab('perfil')" class="font-bold text-blue-900">Perfil</button>
    </nav>

    <main class="max-w-2xl mx-auto p-4">
        <section id="jugar" class="tab-content active bg-white p-6 rounded-xl shadow">
            <h2 class="text-xl font-bold mb-4">Talonario Virtual</h2>
            <input type="number" id="numeroInput" placeholder="Número (000-999)" class="w-full border p-3 rounded mb-2">
            <input type="number" id="montoInput" placeholder="Monto ($)" class="w-full border p-3 rounded mb-4">
            <button onclick="procesarPago()" class="w-full bg-blue-900 text-white p-3 rounded font-bold">Pagar y Jugar</button>
        </section>

        <section id="estrategia" class="tab-content bg-white p-6 rounded-xl shadow">
            <h2 class="text-xl font-bold mb-4">Estrategias</h2>
            <div id="galeriaEstrategias" class="grid grid-cols-2 gap-4"></div>
        </section>

        <section id="calendario" class="tab-content bg-white p-6 rounded-xl shadow">
            <h2 class="text-xl font-bold mb-4">Calendario</h2>
            <table class="w-full text-left">
                <tbody id="tablaCalendario"></tbody>
            </table>
        </section>

        <section id="historial" class="tab-content bg-white p-6 rounded-xl shadow">
            <h2 class="text-xl font-bold mb-4">Historial</h2>
            <table class="w-full text-left" id="tablaHistorial"></table>
        </section>

        <section id="perfil" class="tab-content bg-white p-6 rounded-xl shadow">
            <h2 class="text-xl font-bold mb-4">Mi Perfil</h2>
            <div id="formContainer" class="space-y-3">
                <input type="text" id="userName" placeholder="Nombre" class="w-full border p-2 rounded">
                <input type="text" id="userBank" placeholder="Cuenta Bancaria" class="w-full border p-2 rounded">
                <button onclick="guardarPerfil()" class="w-full bg-green-600 text-white p-2 rounded">Guardar</button>
            </div>
        </section>
    </main>

    <script>
        function showTab(id) {
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }

        // Lógica simplificada de funciones (Integración completa)
        function procesarPago() { alert("Redirigiendo a Mercado Pago..."); }
        function guardarPerfil() { localStorage.setItem('userData', 'registrado'); alert("Datos guardados"); }
        function renderizarHistorial() { /* lógica previa */ }
    </script>
</body>
</html>
